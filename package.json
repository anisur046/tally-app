  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.1",
    "oxlint": "^1.69.0",
    "pkg": "^5.8.1",
    "vite": "^8.1.0"
  }
}
